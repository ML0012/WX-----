# 服务端口
PORT=3000

# 微信支付商户号
WECHAT_MCHID=1900000000

# APIv3 密钥（32字节，用于 AEAD_AES_256_GCM 解密）
WECHAT_APIV3_KEY=your-apiv3-key-32-bytes-long-xxx

# 微信支付平台证书序列号（用于匹配请求头 Wechatpay-Serial）
WECHAT_PLATFORM_SERIAL=your-platform-certificate-serial-number

# 微信支付平台公钥（PEM 格式，换行用 \n 表示）
# 可以是「平台证书」中提取的公钥，也可以是新版「微信支付公钥」
# 示例：WECHAT_PLATFORM_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjAN...\n-----END PUBLIC KEY-----"
WECHAT_PLATFORM_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_KEY_HERE\n-----END PUBLIC KEY-----"
