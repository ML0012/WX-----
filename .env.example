# ============================================================
# 微信支付 Native APIv3 回调服务 - 环境变量配置
# 使用方法：复制本文件为 .env 并填入真实值
#   cp .env.example .env
# ============================================================

# 服务监听端口（可选，默认 3000）
PORT=3000

# ─── 微信支付商户号 ───
# 获取位置：微信商户平台 -> 账户中心 -> 商户信息 -> 微信支付商户号
# 格式：纯数字，10位左右
WECHAT_MCHID=1746251430

# ─── APIv3 密钥 ───
# 获取位置：微信商户平台 -> 账户中心 -> API安全 -> APIv3密钥（设置/重置）
# 要求：必须恰好 32 字节（32 个 ASCII 字符），否则服务启动报错
# 用途：用于 AEAD_AES_256_GCM 解密回调中的 resource 密文
WECHAT_APIV3_KEY=ZKHS20260601zkhs20260601zkhs0106

# ─── 平台证书序列号 / 微信支付公钥 ID ───
# 用途：校验回调请求头 Wechatpay-Serial，不匹配则拒绝请求
# 两种模式（二选一）：
#   模式A - 平台证书模式：填平台证书序列号（40 位十六进制），通过证书下载工具获取
#   模式B - 微信支付公钥模式（推荐）：填公钥 ID，格式形如 PUB_KEY_ID_xxxxxxxxxxxxxxx
#           获取位置：微信商户平台 -> 账户中心 -> API安全 -> 微信支付公钥
WECHAT_PLATFORM_SERIAL=PUB_KEY_ID_0117462514302026060100192244003804

# ─── 微信支付平台公钥（PEM 格式） ───
# 用途：RSA-SHA256 验签，验证回调确实来自微信
# 两种来源（与上面的 SERIAL 对应）：
#   模式A - 从平台证书中提取公钥
#   模式B - 直接使用微信支付公钥（商户平台下载）
# 格式要求：PEM 全文写在一行，原始换行替换为 \n（代码会自动还原）
# 示例：
#   WECHAT_PLATFORM_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhki...(base64内容)...\n-----END PUBLIC KEY-----"
WECHAT_PLATFORM_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\\n-----END PUBLIC KEY-----"
